# Vigzone AI Configuration

# --- Chat backend: local Ollama ---
# Make sure Ollama is running and you've pulled the models below:
#   ollama pull llama3.2
#   ollama pull llava
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_VISION_MODEL=llava

# --- Application ---
ENV=development
PORT=8000
LOG_LEVEL=INFO

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Server ---
WORKERS=4
TIMEOUT=120
