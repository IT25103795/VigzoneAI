# Vigzone AI Configuration
# Copy this file to .env and fill in your values.

# --- Chat backend: local Ollama ---
# Vigzone AI's chat runs entirely on your own machine via Ollama — no API
# key, no internet connection needed once models are pulled.
#
# One-time setup:
#   1. Install Ollama: https://ollama.com/download
#   2. ollama pull llama3.2   (text chat model)
#   3. ollama pull llava      (vision model, for image uploads — optional)
#   4. Make sure Ollama is running (it usually runs automatically after
#      install; otherwise run `ollama serve` in a terminal)
#
# Defaults below assume Ollama is running on its standard local port.
OLLAMA_BASE_URL=http://localhost:11434

# Must be a model you've already pulled (`ollama list` to check).
OLLAMA_MODEL=llama3.2

# Vision model used automatically when an image is attached. Must also be
# pulled separately — llama3.2 itself can't see images.
OLLAMA_VISION_MODEL=llava

# --- Image generation ---
# Provider used by POST /api/generate-image. Defaults to "pollinations",
# which is free and requires no API key. Set to "openai" to use OpenAI's
# Images API instead (requires OPENAI_API_KEY below).
IMAGE_API_PROVIDER=pollinations

# Needed for: (1) IMAGE_API_PROVIDER=openai, and (2) photo editing via
# POST /api/edit-image (editing an uploaded photo always uses OpenAI's
# images/edits endpoint — there's no free provider that can do this).
# OPENAI_API_KEY=your_openai_api_key_here

# --- Application ---
ENV=development
PORT=8000
LOG_LEVEL=INFO

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Server ---
WORKERS=4
TIMEOUT=120
