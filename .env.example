# Vigzone AI Configuration
# ========================
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file — keep it in .gitignore.

# ── Chat backend: local Ollama ────────────────────────────────────────────────
# One-time setup:
#   1. Install Ollama: https://ollama.com/download
#   2. ollama pull gemma3        (text + vision, 140+ languages incl. Sinhala)
#   3. Ollama starts automatically after install; or run: ollama serve
#
# Want a different model instead? Any Ollama model works — just pull it and
# set OLLAMA_MODEL / OLLAMA_VISION_MODEL to its name. llama3.2 + llava is
# faster/lighter but only officially covers ~8 languages, so it's not a good
# fit if you need broad language support (e.g. Sinhala).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3
OLLAMA_VISION_MODEL=gemma3

# ── App mode ──────────────────────────────────────────────────────────────────
# testing    → unlimited messages, no token tracking (default for local dev)
# production → token usage tracked per user in SQLite (for worldwide launch)
APP_MODE=testing

# ── Image generation ──────────────────────────────────────────────────────────
# "pollinations" = free, no API key required (default)
# "openai"       = requires OPENAI_API_KEY below
IMAGE_API_PROVIDER=pollinations
# OPENAI_API_KEY=your_openai_api_key_here

# ── Authentication ────────────────────────────────────────────────────────────
# Email/password auth works out of the box (SQLite, no setup needed).
#
# Google sign-in (optional):
#   1. https://console.cloud.google.com/apis/credentials
#   2. Create OAuth 2.0 Client ID (Web application)
#   3. Add redirect URI: http://localhost:8000/api/auth/google/callback
#   4. Fill in the two values below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ── Real-Time Web Search ──────────────────────────────────────────────────────
# Enables Vigzone to search the web for live info (news, prices, scores, etc.)
# Uses DuckDuckGo — no API key or account required. Requires internet access.
# Set to "false" to disable (Vigzone falls back to model knowledge only).
WEB_SEARCH_ENABLED=true

# Local timezone used for direct date/time answers injected into prompts.
# Use a standard IANA timezone name, for example: Asia/Colombo, Europe/London.
USER_TIMEZONE=Asia/Colombo

# Default place to use when a user asks for weather/forecast without naming a city.
WEATHER_DEFAULT_LOCATION=Colombo, Sri Lanka

# ── Application ───────────────────────────────────────────────────────────────
ENV=development
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
WORKERS=4
TIMEOUT=120
